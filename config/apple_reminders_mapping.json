{
  "version": "0.3.1",
  "timezone": "Asia/Shanghai",
  "description": "Apple Reminders 分类映射配置。与用户当前正式 GTD 列表保持完全一致。",
  "classification_policy": {
    "source_of_truth": "gtd-tasks",
    "reminders_taxonomy_status": "confirmed",
    "default_open_statuses": ["open"],
    "excluded_statuses": ["done", "cancelled", "archived"],
    "rule_priority_order": [
      "manual_category_rules",
      "manual_tag_rules",
      "keyword_rules",
      "fallback_rules"
    ],
    "rule_conflict_resolution": "first_match_wins"
  },
  "lists": [
    {
      "id": "index",
      "name": "收集箱@inbox",
      "status": "active",
      "notes": "默认收集入口，尚未澄清的事项先进入这里。"
    },
    {
      "id": "project",
      "name": "项目@project",
      "status": "active",
      "notes": "需要多步推进、需要持续管理的项目。"
    },
    {
      "id": "next_action",
      "name": "下一步行动@NextAction",
      "status": "active",
      "notes": "已经明确下一步动作、可以直接执行的事项。"
    },
    {
      "id": "waiting_for",
      "name": "等待@Waiting For",
      "status": "active",
      "notes": "等待别人回复、确认、反馈、交付。"
    },
    {
      "id": "maybe",
      "name": "可能的事@Maybe",
      "status": "active",
      "notes": "未来也许要做，但现在不承诺推进。"
    }
  ],
  "rules": [
    {
      "id": "category_waiting_for",
      "name": "任务已显式标记 waiting_for",
      "priority": 120,
      "target_list_id": "waiting_for",
      "all": [
        { "field": "status", "operator": "in", "value": ["open"] },
        { "field": "category", "operator": "equals", "value": "waiting_for" }
      ]
    },
    {
      "id": "category_project",
      "name": "任务已显式标记 project",
      "priority": 119,
      "target_list_id": "project",
      "all": [
        { "field": "status", "operator": "in", "value": ["open"] },
        { "field": "category", "operator": "equals", "value": "project" }
      ]
    },
    {
      "id": "category_next_action",
      "name": "任务已显式标记 next_action",
      "priority": 118,
      "target_list_id": "next_action",
      "all": [
        { "field": "status", "operator": "in", "value": ["open"] },
        { "field": "category", "operator": "equals", "value": "next_action" }
      ]
    },
    {
      "id": "category_maybe",
      "name": "任务已显式标记 maybe",
      "priority": 117,
      "target_list_id": "maybe",
      "all": [
        { "field": "status", "operator": "in", "value": ["open"] },
        { "field": "category", "operator": "equals", "value": "maybe" }
      ]
    },
    {
      "id": "category_index",
      "name": "任务已显式标记 index",
      "priority": 116,
      "target_list_id": "index",
      "all": [
        { "field": "status", "operator": "in", "value": ["open"] },
        { "field": "category", "operator": "equals", "value": "index" }
      ]
    },
    {
      "id": "manual_wait_tag",
      "name": "WAIT 标签优先进入等待",
      "priority": 100,
      "target_list_id": "waiting_for",
      "all": [
        { "field": "status", "operator": "in", "value": ["open"] },
        { "field": "tags", "operator": "contains_any", "value": ["WAIT", "FOLLOWUP", "FOLLOW_UP"] }
      ]
    },
    {
      "id": "keyword_waiting_for",
      "name": "标题或备注出现等待/确认/回复类词语时归入等待",
      "priority": 90,
      "target_list_id": "waiting_for",
      "all": [
        { "field": "status", "operator": "in", "value": ["open"] },
        {
          "any": [
            { "field": "title", "operator": "contains_any_text", "value": ["等待", "等", "确认", "回复", "回信", "跟进", "催", "反馈"] },
            { "field": "note", "operator": "contains_any_text", "value": ["等待", "等", "确认", "回复", "回信", "跟进", "催", "反馈"] }
          ]
        }
      ]
    },
    {
      "id": "bucket_future_to_maybe",
      "name": "future 默认归入可能的事",
      "priority": 70,
      "target_list_id": "maybe",
      "all": [
        { "field": "status", "operator": "in", "value": ["open"] },
        { "field": "bucket", "operator": "equals", "value": "future" }
      ]
    },
    {
      "id": "fallback_open_tasks",
      "name": "默认兜底：所有 open 任务进入收集箱",
      "priority": 10,
      "target_list_id": "index",
      "all": [
        { "field": "status", "operator": "in", "value": ["open"] }
      ]
    }
  ],
  "export": {
    "output_path": "sync/apple-reminders-export.json",
    "include_debug_fields": false,
    "note_template": [
      "{{note}}"
    ]
  }
}
