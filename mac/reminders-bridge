#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import sys
from typing import Any, Dict


def ok(action: str, **kwargs: Any) -> int:
    payload: Dict[str, Any] = {'success': True, 'action': action}
    payload.update(kwargs)
    print(json.dumps(payload, ensure_ascii=False))
    return 0


def fail(action: str, code: str, message: str) -> int:
    print(json.dumps({
        'success': False,
        'action': action,
        'error_code': code,
        'error_message': message,
    }, ensure_ascii=False))
    return 1


def parse() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description='Minimal reminders bridge placeholder for EventKit migration')
    parser.add_argument('action', choices=['check-permission', 'list-calendars', 'create', 'update', 'move', 'complete', 'delete'])
    parser.add_argument('--input-json', dest='input_json', default='')
    return parser.parse_args()


def main() -> int:
    args = parse()
    action = args.action
    payload: Dict[str, Any] = {}
    if args.input_json:
        try:
            payload = json.loads(args.input_json)
            if not isinstance(payload, dict):
                return fail(action, 'INVALID_INPUT', 'input-json must be a JSON object')
        except json.JSONDecodeError as exc:
            return fail(action, 'INVALID_JSON', str(exc))

    if action == 'check-permission':
        return ok(action, permission='unknown', message='placeholder bridge; EventKit implementation pending')

    if action == 'list-calendars':
        return ok(action, calendars=[])

    if action == 'create':
        title = payload.get('title', '')
        list_name = payload.get('list_name', '')
        if not title:
            return fail(action, 'MISSING_TITLE', 'title is required')
        return ok(action, reminder_id='mock-reminder-id', title=title, list_name=list_name, message='placeholder create only')

    if action == 'update':
        reminder_id = payload.get('reminder_id', '')
        if not reminder_id:
            return fail(action, 'MISSING_REMINDER_ID', 'reminder_id is required')
        return ok(action, reminder_id=reminder_id, message='placeholder update only')

    if action == 'move':
        reminder_id = payload.get('reminder_id', '')
        list_name = payload.get('list_name', '')
        if not reminder_id:
            return fail(action, 'MISSING_REMINDER_ID', 'reminder_id is required')
        return ok(action, reminder_id=reminder_id, list_name=list_name, message='placeholder move only')

    if action == 'complete':
        reminder_id = payload.get('reminder_id', '')
        if not reminder_id:
            return fail(action, 'MISSING_REMINDER_ID', 'reminder_id is required')
        return ok(action, reminder_id=reminder_id, completed=True, message='placeholder complete only')

    if action == 'delete':
        reminder_id = payload.get('reminder_id', '')
        if not reminder_id:
            return fail(action, 'MISSING_REMINDER_ID', 'reminder_id is required')
        return ok(action, reminder_id=reminder_id, deleted=True, message='placeholder delete only')

    return fail(action, 'UNKNOWN_ACTION', f'unsupported action: {action}')


if __name__ == '__main__':
    sys.exit(main())
